# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vibe_newsletter
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017/vibe_newsletter

# JWT
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your-refresh-secret-change-this
REFRESH_TOKEN_EXPIRE=30d

# AI Services
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# Email Service
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=newsletters@vibenewsletter.com
FROM_NAME=Vibe Newsletter

# Media Storage
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# External APIs
UNSPLASH_ACCESS_KEY=your-unsplash-key
GIPHY_API_KEY=your-giphy-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000

# Websocket
WS_PORT=5001

# Background Jobs
BULL_REDIS_URL=redis://localhost:6379

# Analytics
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=analytics

# Features
ENABLE_AI_GENERATION=true
ENABLE_PLUGINS=true
ENABLE_COLLABORATION=true
